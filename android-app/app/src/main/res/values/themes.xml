<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - Samsung Prism + OpenClaw -->
    <style name="Theme.GalaxyPulse" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/prism_primary</item>
        <item name="colorPrimaryVariant">@color/prism_primary_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/cosmic_cyan</item>
        <item name="colorSecondaryVariant">@color/cosmic_blue</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">@color/background_primary</item>
        <item name="colorSurface">@color/background_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/background_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/background_primary</item>
        
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        
        <!-- Window animations -->
        <item name="android:windowAnimationStyle">@style/WindowAnimationTransition</item>
        <item name="android:windowContentTransitions">true</item>
    </style>
    
    <!-- Splash/Landing Screen Theme -->
    <style name="Theme.GalaxyPulse.Splash" parent="Theme.GalaxyPulse">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
    
    <!-- Window Animation Style -->
    <style name="WindowAnimationTransition">
        <item name="android:windowEnterAnimation">@anim/slide_in_right</item>
        <item name="android:windowExitAnimation">@anim/slide_out_left</item>
    </style>
    
    <!-- Premium Button Styles -->
    <style name="PremiumButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/prism_primary</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="elevation">8dp</item>
    </style>
    
    <style name="PremiumButton.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/prism_primary</item>
        <item name="android:textColor">@color/prism_primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="strokeWidth">2dp</item>
    </style>
    
    <style name="PremiumButton.Glass" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/surface_glass_light</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="strokeColor">@color/overlay_light</item>
        <item name="strokeWidth">1dp</item>
    </style>
    
    <!-- Premium Card Style -->
    <style name="PremiumCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/background_card</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">12dp</item>
        <item name="strokeWidth">0dp</item>
    </style>
    
    <!-- Glass Card Style -->
    <style name="GlassCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_glass</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/overlay_light</item>
        <item name="strokeWidth">1dp</item>
    </style>
    
    <!-- Text Styles -->
    <style name="TextAppearance.GalaxyPulse.Headline" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>
    
    <style name="TextAppearance.GalaxyPulse.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.GalaxyPulse.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <!-- Input Field Style -->
    <style name="PremiumInputField" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/prism_primary</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="hintTextColor">@color/text_tertiary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
    </style>
    
    <!-- Switch Style -->
    <style name="PremiumSwitch" parent="Widget.Material3.CompoundButton.Switch">
        <item name="thumbTint">@color/text_primary</item>
        <item name="trackTint">@color/prism_primary</item>
    </style>
</resources>
