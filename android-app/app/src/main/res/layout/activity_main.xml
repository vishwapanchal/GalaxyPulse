<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background">

    <!-- Cosmic overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.15"
        android:background="@drawable/gradient_cosmic" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:clipToPadding="false">

            <!-- Premium Header with gradient -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_card_background"
                android:padding="24dp"
                android:layout_marginBottom="24dp"
                android:elevation="8dp">

                <TextView
                    android:id="@+id/tvHeaderTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="GalaxyPulse"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="-0.01"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/statusIndicator" />

                <View
                    android:id="@+id/statusIndicator"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/status_indicator_inactive"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toTopOf="@id/tvHeaderTitle"
                    app:layout_constraintBottom_toBottomOf="@id/tvHeaderTitle"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tvHeaderSubtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Intelligent Device Monitoring"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.05"
                    android:layout_marginTop="4dp"
                    app:layout_constraintTop_toBottomOf="@id/tvHeaderTitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Quick stats row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    app:layout_constraintTop_toBottomOf="@id/tvHeaderSubtitle">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Status"
                            android:textSize="11sp"
                            android:textColor="@color/text_tertiary"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tvStatusValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Inactive"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="@color/overlay_light" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Uptime"
                            android:textSize="11sp"
                            android:textColor="@color/text_tertiary"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tvUptimeValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--:--"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="@color/overlay_light" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Events"
                            android:textSize="11sp"
                            android:textColor="@color/text_tertiary"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tvEventsValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Permission Status Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card_background"
            android:padding="20dp"
            android:layout_marginBottom="20dp"
            android:elevation="4dp">

            <TextView
                android:id="@+id/tvPermissionTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Permissions"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:id="@+id/divider1"
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@drawable/gradient_primary"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvPermissionTitle"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvPermissionStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="❌ Usage Access: Not Granted"
                android:textSize="15sp"
                android:textColor="@color/accent_error"
                android:fontFamily="sans-serif"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/divider1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRequestPermissions"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:text="Grant Usage Access"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/premium_button_background"
                android:letterSpacing="0.02"
                android:layout_marginTop="16dp"
                app:cornerRadius="16dp"
                app:elevation="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvPermissionStatus"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBatteryOptimization"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:text="Disable Battery Optimization"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/glass_card_background"
                android:letterSpacing="0.02"
                android:layout_marginTop="12dp"
                app:strokeColor="@color/accent_warning"
                app:strokeWidth="2dp"
                app:cornerRadius="16dp"
                app:layout_constraintTop_toBottomOf="@id/btnRequestPermissions"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Configuration Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card_background"
            android:padding="20dp"
            android:layout_marginBottom="20dp"
            android:elevation="4dp">

            <TextView
                android:id="@+id/tvConfigTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Configuration"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:id="@+id/divider2"
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@drawable/gradient_cosmic"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvConfigTitle"
                app:layout_constraintStart_toStartOf="parent" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilBackendUrl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="Backend URL"
                android:layout_marginTop="20dp"
                app:boxStrokeColor="@color/prism_primary"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:hintTextColor="@color/text_tertiary"
                app:boxBackgroundColor="@color/surface_glass_light"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:layout_constraintTop_toBottomOf="@id/divider2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBackendUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:text="http://192.168.1.100:8000" />

            </com.google.android.material.textfield.TextInputLayout>
            
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:text="Save Network Config"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/premium_button_background"
                android:letterSpacing="0.02"
                android:layout_marginTop="20dp"
                app:cornerRadius="16dp"
                app:elevation="8dp"
                app:layout_constraintTop_toBottomOf="@id/tilBackendUrl"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Telegram Integration Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card_background"
            android:padding="20dp"
            android:layout_marginBottom="20dp"
            android:elevation="4dp">

            <TextView
                android:id="@+id/tvTelegramTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Telegram Integration"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/cosmic_cyan"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:id="@+id/dividerTelegram"
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@color/cosmic_cyan"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvTelegramTitle"
                app:layout_constraintStart_toStartOf="parent" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilChatId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="Telegram Chat ID"
                android:layout_marginTop="16dp"
                app:boxStrokeColor="@color/prism_primary"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:hintTextColor="@color/text_tertiary"
                app:boxBackgroundColor="@color/surface_glass_light"
                app:helperText="Tap 'Get Chat ID' button below to get yours"
                app:helperTextTextColor="@color/text_tertiary"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:layout_constraintTop_toBottomOf="@id/tilBackendUrl"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etChatId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGetChatId"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:text="📱 Link with Telegram Bot"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/cosmic_cyan"
                android:letterSpacing="0.02"
                android:layout_marginTop="16dp"
                app:cornerRadius="12dp"
                app:layout_constraintTop_toBottomOf="@id/tilChatId"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Monitoring Control Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card_background"
            android:padding="20dp"
            android:layout_marginBottom="20dp"
            android:elevation="4dp">

            <TextView
                android:id="@+id/tvMonitoringTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Monitoring Control"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:id="@+id/divider3"
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@drawable/gradient_primary"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvMonitoringTitle"
                app:layout_constraintStart_toStartOf="parent" />

            <LinearLayout
                android:id="@+id/switchContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/glass_card_background"
                android:padding="16dp"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/divider3"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enable Monitoring"
                        android:textSize="17sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Auto-detect AI app usage"
                        android:textSize="13sp"
                        android:textColor="@color/text_tertiary"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchMonitoring"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/text_primary"
                    app:trackTint="@color/prism_primary"
                    app:trackDecorationTint="@color/surface_glass_light" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Activity Log Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card_background"
            android:padding="20dp"
            android:layout_marginBottom="20dp"
            android:elevation="4dp">

            <TextView
                android:id="@+id/tvActivityLogTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Activity Log"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:id="@+id/dividerLog"
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@drawable/gradient_primary"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvActivityLogTitle"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvActivityLogDesc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Real-time log of detected apps and monitoring events"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/dividerLog"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenLogViewer"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:text="Open Live Log Viewer"
                android:textSize="15sp"
                android:textColor="@color/cosmic_cyan"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/glass_card_background"
                android:letterSpacing="0.02"
                android:layout_marginTop="16dp"
                app:strokeColor="@color/cosmic_purple"
                app:strokeWidth="2dp"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_info_details"
                app:iconTint="@color/cosmic_cyan"
                app:layout_constraintTop_toBottomOf="@id/tvActivityLogDesc"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- System Information Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card_background"
            android:padding="20dp"
            android:layout_marginBottom="20dp"
            android:elevation="4dp">

            <TextView
                android:id="@+id/tvSystemInfoTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="System Information"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:id="@+id/divider4"
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@drawable/gradient_cosmic"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvSystemInfoTitle"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvSystemInfoDesc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="View all collected system information including battery, memory, network, and health context"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/divider4"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTestSystemInfo"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:text="View System Info"
                android:textSize="15sp"
                android:textColor="@color/cosmic_cyan"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/glass_card_background"
                android:letterSpacing="0.02"
                android:layout_marginTop="16dp"
                app:strokeColor="@color/cosmic_cyan"
                app:strokeWidth="2dp"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_info_details"
                app:iconTint="@color/cosmic_cyan"
                app:layout_constraintTop_toBottomOf="@id/tvSystemInfoDesc"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Footer branding -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Made with 💜 by"
                android:textSize="11sp"
                android:textColor="@color/text_tertiary"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.05" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SeriousVibeCoders"
                android:textSize="16sp"
                android:textColor="@color/prism_primary"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Powered by OpenClaw × Samsung Prism"
                android:textSize="10sp"
                android:textColor="@color/text_tertiary"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.05"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
