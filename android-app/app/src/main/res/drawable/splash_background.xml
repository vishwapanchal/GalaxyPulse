<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#0A0E27"
                android:centerColor="#1E2749"
                android:endColor="#2A1B4E"
                android:type="linear" />
        </shape>
    </item>
    
    <!-- Cosmic overlay gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="45"
                android:startColor="#1A7B2FF7"
                android:centerColor="#1A4D7CFE"
                android:endColor="#1A00D9FF"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
