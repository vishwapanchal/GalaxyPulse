# ── GalaxyPulse Backend — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your values

# Server
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/galaxypulse
# For Railway/Render deployment, replace with your hosted DB URL

# OpenRouter — Free LLM API (https://openrouter.ai/keys)
# Sign up free at openrouter.ai → Keys → Create key
OPENROUTER_API_KEY=sk-or-v1-...

# LLM Model (free tier on OpenRouter)
LLM_PRIMARY_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct:free

# JWT Auth (generate: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS — allowed origins for the frontend
CORS_ORIGINS=["http://localhost:3000","https://galaxypulse.vercel.app"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# OpenClaw / Agent
OPENCLAW_WEBHOOK_SECRET=your-webhook-secret
